INTERNAL_JOBS_SECRET=replace-with-a-random-jobs-secret
CLOSED_MEDIA_RETENTION_DAYS=730
GEOCODING_ENABLED=true
GEOCODING_USER_AGENT=CivicLens/1.0 your-email@example.com
